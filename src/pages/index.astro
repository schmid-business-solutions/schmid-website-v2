<!-- Top Navigation -->
<header class="fixed top-0 w-full z-50 glass-nav border-b border-outline-variant/30 bg-surface/80 backdrop-blur-md">
<nav class="flex justify-between items-center max-w-max-width mx-auto px-gutter py-4">
