---
// ContactForm.astro - EmailJS integrated contact form component
---

<form id="contact-form" class="grid grid-cols-1 md:grid-cols-2 gap-8" method="POST">
	<div class="col-span-1">
		<label class="block text-on-surface-variant font-label-lg mb-2">Vorname</label>
		<input
			id="firstName"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="Max"
			type="text"
			required
		/>
	</div>
	<div class="col-span-1">
		<label class="block text-on-surface-variant font-label-lg mb-2">Nachname</label>
		<input
			id="lastName"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="Müller"
			type="text"
			required
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">E-Mail Adresse</label>
		<input
			id="email"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="name@firma.ch"
			type="email"
			required
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">Unternehmen</label>
		<input
			id="company"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="Firma GmbH"
			type="text"
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">Nachricht</label>
		<textarea
			id="message"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none resize-none"
			placeholder="Wie kann ich Ihnen helfen?"
			rows="4"
			required
		></textarea>
	</div>
	<div class="col-span-1 md:col-span-2 mb-2">
		<p class="text-label-sm text-on-surface-variant/70 leading-relaxed">Mit dem Absenden des Formulars erklären Sie sich mit der Verarbeitung Ihrer Daten gemäss der Schweizer Datenschutzgesetzgebung einverstanden.</p>
	</div>
	<div class="col-span-1 md:col-span-2">
		<button
			id="submit-btn"
			class="w-full py-4 bg-tertiary-container text-white rounded-full font-headline-sm hover:brightness-90 hover:shadow-lg transition-all active:scale-95"
			type="submit"
		>Anfrage senden</button>
	</div>
</form>

<script>
	// Initialize EmailJS
	emailjs.init({
		publicKey: 'vV9h_VmtC-_Y0kWKl'
	});

	const form = document.getElementById('contact-form');
	const submitBtn = document.getElementById('submit-btn');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		// Disable submit button and show loading state
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Wird gesendet...';
		}

		const templateParams = {
			to_email: 'office@ivanschmid.com',
			from_name: document.getElementById('firstName')?.value + ' ' + document.getElementById('lastName')?.value,
			from_email: document.getElementById('email')?.value,
			company: document.getElementById('company')?.value || 'Nicht angegeben',
			message: document.getElementById('message')?.value,
			subject: 'Website Anfrage von ivanschmid.com'
		};

		try {
			await emailjs.send('service_ivanschmid', 'template_ivanschmid', templateParams);

			// Show success message
			if (submitBtn) {
				submitBtn.textContent = 'Anfrage erfolgreich gesendet!';
				submitBtn.style.backgroundColor = '#10b981';
			}

			// Reset form
			form.reset();

			// Reset button after 3 seconds
			setTimeout(() => {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = 'Anfrage senden';
					submitBtn.style.backgroundColor = '';
				}
			}, 3000);
		} catch (error) {
			console.error('Failed to send email:', error);

			// Show error message
			if (submitBtn) {
				submitBtn.textContent = 'Fehler beim Senden. Versuchen Sie es später erneut.';
				submitBtn.style.backgroundColor = '#ef4444';
			}

			// Reset button after 3 seconds
			setTimeout(() => {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = 'Anfrage senden';
					submitBtn.style.backgroundColor = '';
				}
			}, 3000);
		}
	});
</script>
