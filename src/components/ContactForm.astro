---
// ContactForm.astro - EmailJS integrated contact form component
---

<form id="contact-form" class="grid grid-cols-1 md:grid-cols-2 gap-8" method="POST">
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">Name</label>
		<input
			id="name"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="Max Müller"
			type="text"
			required
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">E-Mail Adresse</label>
		<input
			id="email"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="name@firma.ch"
			type="email"
			required
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">Anfrage</label>
		<input
			id="request"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none"
			placeholder="Worum geht es?"
			type="text"
			required
		/>
	</div>
	<div class="col-span-1 md:col-span-2">
		<label class="block text-on-surface-variant font-label-lg mb-2">Nachricht</label>
		<textarea
			id="message"
			class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-tertiary-container focus:ring-2 focus:ring-tertiary-container/20 transition-all outline-none resize-none"
			placeholder="Wie kann ich Ihnen helfen?"
			rows="4"
			required
		></textarea>
	</div>
	<div class="col-span-1 md:col-span-2 mb-2">
		<p class="text-label-sm text-on-surface-variant/70 leading-relaxed">Mit dem Absenden des Formulars erklären Sie sich mit der Verarbeitung Ihrer Daten gemäss der Schweizer Datenschutzgesetzgebung einverstanden.</p>
	</div>
	<div id="form-status" class="col-span-1 md:col-span-2 hidden rounded-xl px-4 py-3 text-sm font-medium" role="status" aria-live="polite"></div>
	<div class="col-span-1 md:col-span-2">
		<button
			id="submit-btn"
			class="w-full py-4 bg-tertiary-container text-white rounded-full font-headline-sm hover:brightness-90 hover:shadow-lg transition-all active:scale-95 disabled:opacity-60 disabled:cursor-not-allowed"
			type="submit"
		>Anfrage senden</button>
	</div>
</form>

<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4.4.1/dist/email.min.js"></script>
<script is:inline>
	emailjs.init({
		publicKey: 'vV9h_VmtC-_Y0kWKl'
	});

	const form = document.getElementById('contact-form');
	const submitBtn = document.getElementById('submit-btn');
	const statusBox = document.getElementById('form-status');

	function showStatus(kind, text) {
		if (!statusBox) return;
		statusBox.textContent = text;
		statusBox.classList.remove('hidden');
		if (kind === 'success') {
			statusBox.style.backgroundColor = '#ecfdf5';
			statusBox.style.color = '#065f46';
			statusBox.style.border = '1px solid #a7f3d0';
		} else {
			statusBox.style.backgroundColor = '#fef2f2';
			statusBox.style.color = '#991b1b';
			statusBox.style.border = '1px solid #fecaca';
		}
	}

	function hideStatus() {
		if (!statusBox) return;
		statusBox.classList.add('hidden');
		statusBox.textContent = '';
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		hideStatus();

		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Wird gesendet...';
		}

		const templateParams = {
			to_email: 'schmidmobile@gmail.com',
			from_name: document.getElementById('name')?.value,
			from_email: document.getElementById('email')?.value,
			request: document.getElementById('request')?.value,
			message: document.getElementById('message')?.value,
			subject: 'Website Anfrage von ivanschmid.com'
		};

		try {
			await emailjs.send('service_ivanschmid', 'template_ivanschmid', templateParams);

			showStatus('success', 'Vielen Dank! Ihre Anfrage wurde erfolgreich versendet. Wir melden uns in Kürze bei Ihnen.');
			form.reset();

			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Anfrage senden';
			}
		} catch (error) {
			console.error('Failed to send email:', error);
			showStatus('error', 'Beim Senden ist ein Fehler aufgetreten. Bitte versuchen Sie es später erneut oder schreiben Sie direkt an office@ivanschmid.com.');

			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Anfrage senden';
			}
		}
	});
</script>
